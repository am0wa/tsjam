{
  "name": "@tsjam/monorepo",
  "version": "1.0.0",
  "description": "Main repository for tsjam packages",
  "scripts": {
    "lint": "pnpm --filter=tsjam lint",
    "test": "pnpm --filter=tsjam test",
    "build": "pnpm --filter=tsjam build",
    "format": "prettier './**/**.{js,jsx,ts,tsx,css,scss}' --write",
    "prepare": "husky"
  },
  "keywords": [
    "pnpm-monorepo"
  ],
  "author": "am0wa",
  "license": "ISC",
  "engines": {
    "node": ">=24",
    "pnpm": ">=11"
  },
  "devDependencies": {
    "@tsjam/eslint-config-recommended": "workspace:*",
    "@tsjam/lint-config": "workspace:*",
    "@tsjam/tsconfig-bases": "workspace:*",
    "eslint": "catalog:lint",
    "eslint-config-prettier": "catalog:lint",
    "husky": "catalog:lint",
    "lint-staged": "catalog:lint",
    "prettier": "catalog:lint",
    "reflect-metadata": "^0.2.2",
    "rimraf": "catalog:tools",
    "typescript-eslint": "catalog:lint",
    "typescript": "catalog:"
  },
  "prettier": "@tsjam/lint-config/prettier.config.mjs",
  "lint-staged": {
    "*.{ts,tsx}": "eslint --cache --fix",
    "*.{ts,tsx,js,css,md}": "prettier --write"
  },
  "packageManager": "pnpm@11.10.0+sha512.0b7f8b98060031904c017e3a41eb187a16d40eeb829b95c4f8cb03681761fc4ab53dd219115b9b447f4dce1a05a214764461e7d3703392a9f32f9511ce8c86c8",
  "dependencies": {
    "@trivago/prettier-plugin-sort-imports": "^5.2.2"
  }
}
