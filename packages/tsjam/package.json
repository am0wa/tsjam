{
  "name": "tsjam",
  "version": "1.9.2",
  "description": "vanilla typescript sweets",
  "main": "lib/index.js",
  "typings": "lib/index.d.ts",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": "./lib/index.js",
      "require": "./lib/index.js",
      "types": "./lib/index.d.ts",
      "default": "./lib/index.js"
    },
    "./package.json": "./package.json",
    "./money": {
      "require": "./lib/money/index.js",
      "import": "./lib/money/index.js",
      "types": "./lib/money/index.d.ts",
      "default": "./lib/money/index.d.ts"
    },
    "./reactive": {
      "require": "./lib/reactive/index.js",
      "import": "./lib/reactive/index.js",
      "types": "./lib/reactive/index.d.ts",
      "default": "./lib/reactive/index.js"
    }
  },
  "repository": "https://github.com/am0wa/tsjam",
  "license": "MIT",
  "keywords": [
    "typescript",
    "utils",
    "disposable",
    "rx-disposable",
    "rx-tools"
  ],
  "publishConfig": {
    "registry:": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsc -b src/tsconfig.json",
    "build:watch": "tsc -b tsconfig.json -w",
    "lint": "eslint src",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js tests",
    "test:watch": "jest tests --watchAll",
    "doc": "pnpm run doc:html",
    "doc:html": "typedoc src/ --tsconfig src/tsconfig.json --exclude **/*.spec.ts --out docs",
    "doc:publish": "gh-pages -m \"[ci skip] Updates\" -d docs",
    "clean": "pnpm run clean:dist",
    "clean:dist": "rimraf lib",
    "reset-hard": "git clean -f -d && git reset --hard && pnpm i",
    "patch-version": "pnpm version patch",
    "prepare-release": "pnpm run clean:dist && pnpm run lint && pnpm run test && pnpm run patch-version && pnpm run doc:html",
    "prepublishOnly": "pnpm run clean:dist && pnpm run build && pnpm run test",
    "publish-public": "pnpm publish --access=public",
    "postpublish": "git push --tags origin master"
  },
  "engines": {
    "node": ">=22"
  },
  "peerDependencies": {
    "rxjs": "^7.x"
  },
  "devDependencies": {
    "@swc/core": "catalog:swc",
    "@swc/jest": "catalog:jest",
    "@tsjam/lint-config": "workspace:*",
    "@tsjam/swc-jest-config-recommended": "workspace:*",
    "@types/jest": "catalog:jest",
    "@types/node": "^24.3.1",
    "gh-pages": "^6.3.0",
    "jest": "catalog:jest",
    "rxjs": "^7.8.2",
    "ts-jest-resolver": "catalog:jest",
    "typedoc": "^0.28.20"
  },
  "files": [
    "lib",
    "tsconfig.json",
    "!**/tsconfig.tsbuildinfo"
  ],
  "prettier": "@tsjam/lint-config/prettier.config.mjs"
}
