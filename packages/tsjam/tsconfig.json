{
  "extends": "@tsjam/tsconfig-bases/tsconfig.base.json",
  "compilerOptions": {
    "module": "NodeNext",
    "target": "ES2024",
    "moduleResolution": "nodenext",
    "allowJs": true,
    /* Paths (relative to this tsconfig, baseUrl is removed in TS 6) */
    "outDir": "lib",
    "paths": {
      "*": ["./*", "./src/*"]
    },
  },
}
